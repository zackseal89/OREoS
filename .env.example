# ── Client (safe to expose in the browser — every table is protected by RLS) ──
# From: Supabase dashboard → Project Settings → API, or `supabase status` for local dev.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Server-only secrets ───────────────────────────────────────────────────────
# NEVER prefix these with VITE_ (that would ship them to the browser bundle).
# Set for Edge Functions with:  supabase secrets set GEMINI_API_KEY=...
GEMINI_API_KEY=

# Firecrawl — robust web scraping for product-URL dossier extraction.
# Set with:  supabase secrets set FIRECRAWL_API_KEY=fc-...
FIRECRAWL_API_KEY=

# Google OAuth (only needed once Google sign-in is enabled in config.toml)
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
